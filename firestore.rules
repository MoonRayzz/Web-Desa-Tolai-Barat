rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /berita/{doc}    { allow read: if true; allow write: if request.auth != null; }
    match /wisata/{doc}    { allow read: if true; allow write: if request.auth != null; }
    match /umkm/{doc}      { allow read: if true; allow write: if request.auth != null; }
    match /galeri/{doc}    { allow read: if true; allow write: if request.auth != null; }
    match /perangkat/{doc} { allow read: if true; allow write: if request.auth != null; }
    match /settings/{doc}  { allow read: if true; allow write: if request.auth != null; }

    // Analytics — siapapun bisa tulis (tracking), hanya admin bisa baca
    match /analytics_visits/{doc} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /analytics_daily/{doc} {
      allow read: if request.auth != null;
      allow write: if true;
    }
  }
}