rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Koleksi publik — siapapun boleh baca
    match /settings/{docId}          { allow read: if true; allow write: if false; }
    match /berita/{docId}            { allow read: if true; allow write: if false; }
    match /wisata/{docId}            { allow read: if true; allow write: if false; }
    match /potensi/{docId}           { allow read: if true; allow write: if false; }
    match /bumdes/{docId}            { allow read: if true; allow write: if false; }
    match /galeri/{docId}            { allow read: if true; allow write: if false; }
    match /layanan/{docId}           { allow read: if true; allow write: if false; }
    match /perangkat/{docId}         { allow read: if true; allow write: if false; }
    match /fasilitas/{docId}         { allow read: if true; allow write: if false; }
    match /pengumuman/{docId}        { allow read: if true; allow write: if false; }
    match /agenda/{docId}            { allow read: if true; allow write: if false; }
    match /survei/{docId}            { allow read: if true; allow write: if false; }

    // Survei jawaban — publik bisa tulis (submit), tidak bisa baca
    match /survei_jawaban/{docId}    { allow create: if true; allow read, update, delete: if false; }

    // Analytics — publik bisa tulis (log visit), hanya admin bisa baca
    match /analytics_visits/{docId} { allow create: if true; allow read: if request.auth != null; }
    match /analytics_daily/{docId}  { allow read, write: if request.auth != null; }

    // Semua write lainnya harus login
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
